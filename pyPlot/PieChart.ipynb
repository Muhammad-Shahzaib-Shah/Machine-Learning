    "\n",
    "regions = [\"North\",\"South\",\"East\",\"West\"]\n",
    "revenue = [5000,10000,8500,4500]\n",
    "plt.pie(revenue, labels= regions, autopct='%1.1f%%',colors=[\"#DF4661\",\"#0892d0\",\"#FA4616\",\"#21AD34\"])\n",
    "plt.title(\"Revenue COntribution by region\")\n",
    "plt.show()"
