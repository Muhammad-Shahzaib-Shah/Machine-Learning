   "source": [
    "import matplotlib.pyplot as plt\n",
    "x = [1,2,3,4]\n",
    "y = [10,20,15,25]\n",
    "plt.subplot(1,2,1)\n",
    "plt.plot(x,y)\n",
    "plt.title(\"Line Chart\")\n",
    "plt.subplot(1,2,2)\n",
    "plt.bar(x,y)\n",
    "plt.title(\"Bar Chart\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
