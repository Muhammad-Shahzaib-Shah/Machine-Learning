   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# fig,ax = plt.subplots(nrows,ncols,figsize=(width, height))\n",
    "fig,ax = plt.subplots(1,2)\n",
    "x = [1,2,3,4]\n",
    "y = [10,20,15,25]\n",
    "ax[0].plot(x,y)\n",
    "ax[0].set_title('Line Chart')\n",
    "ax[1].bar(x,y,color='green')\n",
    "ax[1].set_title('Bar Chart')\n",
    "\n",
    "plt.show()\n"
   ]
